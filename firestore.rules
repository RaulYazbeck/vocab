// Firestore security rules — reference copy.
// Apply in: Firebase console → Firestore Database → Rules → paste → Publish.
// Each signed-in user can only read/write their own documents.
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
